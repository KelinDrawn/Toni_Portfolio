---
import Picture from "astro/components/Picture.astro";

/* Images */
import Toni from "/src/images/toni_outdoors.png";

import Studies from "/src/images/icons/Studies-icon.svg";
import Flower from "/src/images/icons/Flower-icon.svg";
import Coffeemachine from "/src/images/icons/Coffeemachine-icon.svg";
import Globe from "/src/images/icons/Globe-icon.svg";
import Calendar from "/src/images/icons/Calendar-icon.svg";
import Tools from "/src/images/icons/Tools-icon.svg";
import Conversation from "/src/images/icons/Conversation-icon.svg";
import Mac from "/src/images/icons/Mac-icon.svg";
import Diploma from "/src/images/icons/Diploma-icon.svg";
import ElectricVehicle from "/src/images/icons/Electric-vehicle-icon.svg";
import Books from "/src/images/icons/Books-icon.svg";

import DiplomCSSforJS from "@/images/about/CSS-for-Javascript-Developers-Certificate-Toni-Schlaeppi.png";
import DiplomWhimsicalAnimations from "@/images/about/Whimsical-Animations-Certificate-Toni-Schlaeppi.png";
import DiplomCompleteCSS from "@/images/about/Complete-CSS-Certificate-Toni-Schlaeppi.png";
import DiplomCD from "/src/images/about/TS-Diplom-dipl-Gestalter-HF.jpeg";

import ExternalLink from "/src/images/icons/External-link-icon.svg";

/* Components */
import PopoverCountries from "../components/bento/popover-countries.astro";
import SelectSports from "../components/bento/select-sports.astro";

import PopoverWithProps from "@/components/blog/popoverPicture.astro";

const { class: className, title } = Astro.props;
---

<section class:list={[className, "stack-m main"]}>
  <h2 class="title-1-lines">Toni Schläppi</h2>
  <h3 class="title-6">Curiosities & Credentials</h3>

  <div class="card-grid">
    <section class="card-grid-cell stack-xs">
      <Studies />
      <h4 class="title-1">I studied</h4>

      <PopoverWithProps
        title="2"
        popovertarget="CommunicationDesign"
        popoverPicture={DiplomCD}
        popoverPictureAlt={"Advanced Diploma in Communication Design (HF) Specializing in Interaction Design for Toni Schläppi"}
      >
        Communication Design
      </PopoverWithProps>
    </section>
    <section class="card-grid-cell stack-xs">
      <Diploma />
      <h4 class="title-1">Finished courses</h4>
      <div class="stack-xxs">
        <PopoverWithProps
          popovertarget="CSSforJS"
          popoverPicture={DiplomCSSforJS}
          popoverPictureAlt={"Certificate for Toni Schläppi upon completion of the “CSS for JavaScript Developers” course"}
        >
          CSS for JS Developers
        </PopoverWithProps>
        <PopoverWithProps
          popovertarget="CompleteCSS"
          popoverPicture={DiplomCompleteCSS}
          popoverPictureAlt={"Certificate for Toni Schläppi upon completion of the “Complete CSS” course"}
        >
          Complete CSS
        </PopoverWithProps>
        <PopoverWithProps
          popovertarget="WhimsicalAnimations"
          popoverPicture={DiplomWhimsicalAnimations}
          popoverPictureAlt={"Certificate for Toni Schläppi upon completion of the “Whimsical Animations” course"}
        >
          Whimsical Animations
        </PopoverWithProps>
      </div>
    </section>
    <section class="card-grid-cell stack-xs">
      <Coffeemachine />
      <h4 class="title-1">I love brewing coffee, my current favourite</h4>
      <h5 class="title-1">
        <a href="https://kaffeemacher.ch/products/komal" target="_blank"
          >Komal</a
        ><ExternalLink class="ExternalLink" />
      </h5>
    </section>
    <section class="card-grid-cell stack-xs time-spent-in-industry">
      <Calendar />
      <h5 class="title-1">11+ years of industry experience</h5>
    </section>

    <section class="card-grid-cell stack-xs span-2">
      <SelectSports />
    </section>

    <section class="card-grid-cell stack-xs">
      <ElectricVehicle />
      <h4 class="title-1">
        My car has driven <span class="title-1">62512km.</span> It’s battery health
        is at <span class="title-1">92%</span>
      </h4>
    </section>
    <section class="card-grid-cell stack-xs">
      <Mac />
      <h4 class="title-1">My plattform of choice is MacOS</h4>
    </section>
    <section class="card-grid-cell stack-xs">
      <Conversation />
      <h4 class="title-1">I speak Swissgerman, English and some French</h4>
    </section>
    <section class="card-grid-cell stack-xs">
      <Globe />
      <h4 class="title-1">I have traveled to</h4>
      <PopoverCountries />
    </section>
    <section class="stack-xs toni-profile-picture">
      <Picture
        class="toni"
        src={Toni}
        alt="Toni Schläppi – the author of this website – hiking outdoors"
      />
    </section>
    <section class="card-grid-cell stack-xs">
      <Tools />
      <h4 class="title-1">Toolbelt</h4>
      <h4 class="title-0">
        Figma, Zed, HTML&CSS, JS, SVG, Astro, Motion, Polypane
      </h4>
    </section>
    <section class="card-grid-cell stack-xs">
      <Books />
      <h4 class="title-1">Now reading</h4>
      <h5 class="title-2">
        <a href="https://www.mcdbooks.com/books/user-friendly" target="_blank"
          >User Friendly</a
        ><ExternalLink class="ExternalLink" />
      </h5>

      <h6 class="title-0">by Cliff Kuang and Robert Fabricant</h6>
    </section>
    <section class="card-grid-cell stack-xs quote">
      <Flower />
      <h4 class="title-1">
        «Be humbler about what you know, more confident about what is possible,
        and less afraid of things that do not matter.»
      </h4>
      <h5 class="title-0">by Tim Urban</h5>
    </section>
  </div>
</section>

<style>
  section.main {
    background: var(--section-linear-gradient);

    padding: var(--space-l);
    outline: var(--border-transparent);
    border-radius: var(--border-radius-big);
  }

  h3 {
    text-align: center;
    margin-block-end: var(--space-l);
  }

  .card-grid {
    display: grid;
    grid-gap: var(--space-m);

    /* make the cards square with a pseudo element */
    &::before {
      content: "";
      aspect-ratio: 1;
      grid-row: 1 / 1;
      grid-column: 1 / 1;
    }

    & > *:first-child {
      grid-row: 1 / 1;
      grid-column: 1 / 1;
    }

    & {
      grid-template-columns: repeat(auto-fill, minmax(min(12rem, 35%), 1fr));
      grid-auto-rows: 1fr;
    }

    & .card-grid-cell {
      display: flex;
      flex-direction: column;
      /* TODO: Row on small screens? */
      justify-content: center;
      align-items: center;
      text-align: center;
      /* outline: revert; */
      grid-auto-flow: row dense;

      /* line-height fixes for bento */
      :global(button),
      .title-0,
      .title-1,
      .title-2,
      .title-3 {
        line-height: 1.2;
      }

      padding: var(--space-s);
      /* calculate the border radius:
       Reference: https://www.30secondsofcode.org/css/s/nested-border-radius/
       */
      border-radius: calc(var(--border-radius) + var(--space-s));
      transition: background var(--transition-initial);

      background: light-dark(
        oklch(from var(--color-white) l c h / 0.8),
        oklch(from var(--color-black) l c h / 0.02)
      );

      @media (hover: hover) {
        &:hover {
          transition: background var(--transition-hover);
          background-color: light-dark(
            #fff,
            oklch(from var(--color-black) l c h / 0.025)
          );
          outline: 1px solid
            light-dark(var(--color-lightgrey), var(--color-lightgrey));
        }
      }
    }

    & svg {
      width: clamp(3rem, 50%, 4rem);
      user-select: none;
    }
  }

  .span-2 {
    grid-column: span 2;
    grid-auto-flow: row dense;
  }

  .quote {
    grid-column: span 3;

    & > * {
      max-width: 50ch;
    }

    @media (max-width: 60rem) {
      & {
        grid-column: span 2;
      }
    }
    @media (max-width: 40rem) {
      & {
        grid-column: auto;
      }
    }
  }

  /* Card specific adjustments  */

  .toni-profile-picture {
    overflow: hidden;
    border-radius: calc(var(--border-radius) + var(--space-s));
  }

  .toni-profile-picture img {
    filter: var(--theme-filter);
    transform: scale(1.35);
  }

  .time-spent-in-industry > *:first-child {
    font-family: var(--text-typeface);
    font-size: calc(var(--step-6) * 2);
  }

  .ExternalLink {
    max-width: 1rem;
    margin-inline-start: 0.5ch;
    text-decoration-skip-ink: none;
  }

  a {
    background-color: var(--color-highlight);
  }
</style>

<style is:global>
  /* TODO: Find a better solution for this workaround because the popover styles it’s parent but I don’t want that to happen for my casestudy page   */
  button.popover-button {
    background-color: var(--color-highlight);
    margin-inline: auto;
  }
</style>
