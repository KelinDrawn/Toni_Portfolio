---
import UXFieldStudies from "./animated_icons/ux-field-studies.astro";
import UserResearch from "./animated_icons/user-research.astro";
import Prototyping from "./animated_icons/prototyping.astro";
import UIDesign from "./animated_icons/ui-design.astro";
import DesignSystems from "./animated_icons/design-systems.astro";
import FrontendEngineering from "./animated_icons/frontend-engineering.astro";
import UsabilityTesting from "./animated_icons/usability-testing.astro";
import Benchmarking from "./animated_icons/benchmarking.astro";

const { class: className } = Astro.props;
---

<section class:list={["stack-m main", className]}>
  <h2 class="title-1-lines">User Experience Design</h2>
  <h3 class="title-6">My Core Expertise & Services</h3>

  <div class="card-grid">
    <UXFieldStudies />
    <UserResearch />
    <Prototyping />
    <UIDesign />
    <DesignSystems />
    <FrontendEngineering />
    <UsabilityTesting />
    <Benchmarking />
  </div>
</section>

<style>
  section.main {
    background: var(--section-linear-gradient);

    padding: var(--space-2xl);
    outline: var(--border-transparent);
    border-radius: var(--border-radius-big);
  }

  h3 {
    text-align: center;
    margin-block-end: var(--space-l);
  }

  .card-grid {
    display: grid;
    grid-gap: var(--space-m);

    /* make the cards square with a pseudo element */
    &::before {
      content: "";
      aspect-ratio: 1;
      grid-row: 1 / 1;
      grid-column: 1 / 1;
    }

    & > :global(*:first-child) {
      grid-row: 1 / 1;
      grid-column: 1 / 1;
    }

    & {
      grid-template-columns: repeat(auto-fill, minmax(min(13rem, 35%), 1fr));
      grid-auto-rows: 1fr;
    }
  }

  :global(.card-grid-cell) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;

    background: light-dark(
      oklch(from var(--color-white) l c h / 0.8),
      oklch(from var(--color-black) l c h / 0.02)
    );

    padding: var(--space-m);
    border-radius: calc(var(--border-radius) + var(--space-s));
    transition: background var(--transition-initial);

    @media (hover: hover) {
      &:hover {
        transition: background var(--transition-hover);
        background-color: light-dark(
          #fff,
          oklch(from var(--color-black) l c h / 0.025)
        );
        outline: 1px solid
          light-dark(var(--color-lightgrey), var(--color-lightgrey));
      }
    }
    :global(svg) {
      width: clamp(3rem, 50%, 4rem);
      user-select: none;
    }
  }
</style>
