---
import DecorationBlobXs from "../components/decoration-blob-xs.astro";
---

<!-- <DecorationBlobXs /> -->
<div class="buttongroup">
  <a href="/blog/cs-swisscharge" class="pushable">
    <span class="shadow"></span>
    <span class="edge"></span>
    <span class="front">My Latest Case Study</span>
  </a>
  <a
    href="mailto:toni.schlaeppi@icloud.com"
    class="pushable light"
    id="contact-me"
  >
    <span class="shadow"></span>
    <span class="edge"></span>
    <span class="front">Email Me</span>
  </a>
</div>

<style>
  #contact-me {
    scroll-margin-block-start: 50vh;
  }

  .buttongroup {
    --button-border-radius: 8px;

    user-select: none;
    display: flex;
    gap: var(--space-s, 1rem);
  }

  .pushable {
    display: inline-block;
    position: relative;
    border: none;
    background: transparent;
    user-select: none;
    padding: 0;
    cursor: pointer;
    outline-offset: 6px;
    transition: filter 250ms;
    text-decoration: none;
  }

  .shadow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: var(--button-border-radius);
    background: hsl(0deg 0% 0% / 0.25);
    will-change: transform;
    transform: translateY(2px);
    transition: transform 600ms cubic-bezier(0.3, 0.7, 0.4, 1);
    z-index: 1;
  }

  .edge {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: var(--button-border-radius);
    background: linear-gradient(
      to left,
      oklch(65% 0.021 225) 0%,
      oklch(70% 0.021 225) 8%,
      oklch(70% 0.021 225) 92%,
      oklch(65% 0.021 225) 100%
    );
    z-index: 2;
  }

  .front {
    display: block;
    position: relative;
    padding: 0.8ex 3ex 0.7ex 3ex;
    border-radius: var(--button-border-radius);
    font-size: var(--step-1);
    color: var(--color-black);
    background: light-dark(oklch(95% 0.025 225), var(--color-highlight));
    will-change: transform;
    border: 1px solid var(--color-black);
    transform: translateY(-4px);
    transition: transform 600ms cubic-bezier(0.3, 0.7, 0.4, 1);
    z-index: 3;
  }

  .light .front {
    background-color: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-black);
    font-weight: 100;
  }

  .light .edge {
    background: linear-gradient(
      to left,
      oklch(55% 0 225) 0%,
      oklch(70% 0 225) 8%,
      oklch(70% 0 225) 92%,
      oklch(55% 0 225) 100%
    );
  }

  .pushable:hover {
    filter: saturate(140%);
  }

  .pushable:hover .front {
    transform: translateY(-6px);
    transition: transform 250ms cubic-bezier(0.3, 0.7, 0.4, 1.5);
  }

  .pushable:active .front {
    transform: translateY(-2px);
    transition: transform 34ms;
  }

  .pushable:hover .shadow {
    transform: translateY(4px);
    transition: transform 250ms cubic-bezier(0.3, 0.7, 0.4, 1.5);
  }

  .pushable:active .shadow {
    transform: translateY(1px);
    transition: transform 34ms;
  }

  .pushable:focus:not(:focus-visible) {
    outline: none;
  }
</style>
