---
import Picture from "astro/components/Picture.astro";

import Studies from "/src/images/icons/Studies-icon.svg";
import Flower from "/src/images/icons/Flower-icon.svg";
import Prototyping from "/src/images/icons/Prototyping-icon.svg";
import UserResearch from "/src/images/icons/UX-Field-Studies-icon.svg";
import UIDesign from "/src/images/icons/Mac-icon.svg";

const icons = [
  { Component: Flower, name: "Heuristic Evaluation" },
  { Component: Prototyping, name: "Prototyping" },
  { Component: UIDesign, name: "User Interface Design" },
  { Component: Studies, name: "Market Research" },
  { Component: UserResearch, name: "User Research" },
];
---

<aside class="stack-xs">
  <h3 class="title-1">Core Activities</h3>
  <section>
    <ul class="cluster">
      {
        icons.map(({ Component, name }) => (
          <li>
            <!-- <Component /> -->
            <p class="title-0">{name}</p>
          </li>
        ))
      }
    </ul>
  </section>
</aside>

<style>
  .cluster {
    gap: var(--space-xs) var(--space-xs);
  }



  li {
    padding: 0.1rem 0.3rem 0.05rem 0.3rem;
    background-color: color-mix(
      in oklch,
      var(--color-white),
      var(--color-black) 3%
    );

    border: 1px solid
      light-dark(
        color-mix(in oklch, var(--color-white), var(--color-black) 20%),
        color-mix(in oklch, var(--color-white), var(--color-black) 20%)
      );
    border-radius: var(--border-radius);
  }
</style>
