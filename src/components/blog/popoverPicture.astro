---
import { Picture } from "astro:assets";

const {
  popovertarget,
  popoverPicture,
  popoverPictureAlt,
  class: className,
  title,
} = Astro.props;

const anchorName = `--${popovertarget}`;
---

<button
  popovertarget={popovertarget}
  class:list={["popover-button", className, title && `title-${title}`]}
  style={`anchor-name: --${popovertarget};`}
>
  <span class="slot"><slot /></span>
</button>

<span
  id={popovertarget}
  popover="auto"
  style={`position-anchor: ${anchorName};`}
>
  <Picture src={popoverPicture} alt={popoverPictureAlt} loading="eager" />
</span>

<style>
  [popover] {
    &,
    &::backdrop {
      transition:
        display 0s ease-out allow-discrete,
        overlay 0.25s ease-out allow-discrete,
        opacity 0.25s ease-out,
        transform 0.25s ease-out;

      /* Exit Stage To */
      opacity: 0;
      will-change: opacity, transform;
      backface-visibility: hidden;
    }

    /* On Stage */
    &:popover-open {
      opacity: 1;

      &::backdrop {
        opacity: 0.5;
      }
    }

    /* Enter Stage From */
    @starting-style {
      &:popover-open,
      &:popover-open::backdrop {
        opacity: 0;
        will-change: opacity, transform;
        backface-visibility: hidden;
      }

      &:popover-open {
        transform: translateY(1ex);
      }
    }

    padding: 0;
    margin: unset;

    inset: auto;

    position-area: top right;

    position-try-fallbacks:
      flip-block,
      flip-inline,
      flip-block flip-inline;

    /*position-visibility: visible;*/

    pointer-events: none;
    user-select: none;
    border: none;

    width: fit-content;
    height: fit-content;

    & img {
      display: block;
      padding: 0;
      margin: 0;

      width: auto;
      height: auto;

      /* POPOVER SIZE ADJUSTMENT */
      max-width: max(40vw, 14rem);
      max-height: 65vh;
      object-fit: contain;
    }
  }

  ::backdrop {
    background-color: var(--color-white);
  }

  /* Disable backdrop-filter on Safari (macOS and iOS) to avoid flicker with popover transforms */
  @supports (background: -webkit-named-image(apple-pay-logo-white)) {
    ::backdrop {
      background-color: initial;
    }
  }

  button.popover-button {
    user-select: text;
    padding: unset;
    border: unset;
    border-radius: unset;
    cursor: pointer;

    & span {
      text-decoration: underline;
      background-color: var(--color-highlight);
    }

    &:focus-visible {
      --outline-size: max(2px, 0.15em);
      outline: var(--outline-width, var(--outline-size))
        var(--outline-style, solid) var(--outline-color, currentColor);
      outline-offset: var(--outline-offset, var(--outline-size));
    }
  }
</style>

<script>
  if (window.matchMedia("(hover: hover)").matches) {
    document.addEventListener("mouseover", (e) => {
      const button = e.target.closest(".popover-button");
      if (button) {
        const popover = document.getElementById(
          button.getAttribute("popovertarget"),
        );
        popover?.showPopover();
      }
    });

    document.addEventListener("mouseout", (e) => {
      const button = e.target.closest(".popover-button");
      if (button) {
        const popover = document.getElementById(
          button.getAttribute("popovertarget"),
        );
        popover?.hidePopover();
      }
    });
  }
</script>
