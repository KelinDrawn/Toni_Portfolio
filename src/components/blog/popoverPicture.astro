---
import { Picture } from "astro:assets";

const {
  popovertarget,
  popoverPicture,
  popoverPictureAlt,
  class: className,
  title,
} = Astro.props;

const anchorName = `--${popovertarget}`;
---

<button
  popovertarget={popovertarget}
  class:list={["popover-button", className, title && `title-${title}`]}
  style={`anchor-name: --${popovertarget};`}
>
  <slot />
</button>

<span
  id={popovertarget}
  popover="auto"
  style={`position-anchor: ${anchorName};`}
>
  <Picture src={popoverPicture} alt={popoverPictureAlt} loading="eager" />
</span>

<style>
  [popover]
 /* TRANSITION STYLES */ {
    &,
    &::backdrop {
      transition:
        display 0s ease-out allow-discrete,
        overlay 0.25s ease-out allow-discrete,
        opacity 0.25s ease-out,
        transform 0.25s ease-out;

      /* Exit Stage To */
      opacity: 0;
      will-change: opacity, transform;
      backface-visibility: hidden;
    }

    /* On Stage */
    &:popover-open {
      opacity: 1;

      &::backdrop {
        opacity: 0.5;
      }
    }

    /* Enter Stage From */
    @starting-style {
      &:popover-open,
      &:popover-open::backdrop {
        opacity: 0;
        will-change: opacity, transform;
        backface-visibility: hidden;
      }

      &:popover-open {
        transform: translateY(1ex);
      }
    }

    padding: 0;
    margin: unset;

    position: absolute;
    inset: auto;
    bottom: anchor(top);
    left: anchor(right);

    /*position-visibility: no-overflow;*/

    pointer-events: none;
    user-select: none;
    border: none;
    border-radius: var(--border-radius);

    /*min-width: min(15vw, 10rem);*/
    min-width: 10rem;
    max-width: 20rem;
    /* experiment with clamp and/or min where one value is a percentage
    of the viewport width and the other one a fixed value like rem */

    overflow: auto;

    @media (min-width: 75rem) {
      max-width: 23vw;
    }

    overflow: auto;

    position-try-fallbacks:
      flip-block,
      flip-inline,
      flip-block flip-inline;

    & img {
      overflow: hidden;
      display: block;
      padding: 0;
      margin: 0;
      width: 100%;
      object-fit: contain;
    }
  }

  /* Built-in keywords flip-block and flip-inline are used instead of custom @position-try rules for better reliability and simplicity */

  button.popover-button {
    user-select: text;
    padding: unset;
    border: unset;
    border-radius: unset;

    margin-inline: auto;

    text-decoration: underline;
    display: inline-block;
    cursor: pointer;

    & span {
      display: inline-block;
      text-decoration: none;
    }

    &:focus-visible {
      --outline-size: max(2px, 0.15em);
      outline: var(--outline-width, var(--outline-size))
        var(--outline-style, solid) var(--outline-color, currentColor);
      outline-offset: var(--outline-offset, var(--outline-size));
    }
  }
</style>

<script>
  if (window.matchMedia("(hover: hover)").matches) {
    document.addEventListener("mouseover", (e) => {
      const button = e.target.closest(".popover-button");
      if (button) {
        const popover = document.getElementById(
          button.getAttribute("popovertarget"),
        );
        popover?.showPopover();
      }
    });

    document.addEventListener("mouseout", (e) => {
      const button = e.target.closest(".popover-button");
      if (button) {
        const popover = document.getElementById(
          button.getAttribute("popovertarget"),
        );
        popover?.hidePopover();
      }
    });
  }
</script>
