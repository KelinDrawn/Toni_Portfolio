---
import BaseLayout from "../layouts/baseLayout.astro";

import Navigation from "../layouts/navigation.astro";
import Intro from "../layouts/intro.astro";
import Skillsbox from "../layouts/skillsbox/skillsbox.astro";
import List from "../layouts/list.astro";
import BigCta from "../layouts/big-cta.astro";
import Footer from "../layouts/footer.astro";

const pageTitle = "UX Portfolio of Toni Schläppi";
---

<BaseLayout pageTitle={pageTitle}>
  <Navigation />

  <main class="stack-4xl">
    <Intro class:list={["site-wrapper"]} />
    <!-- <CaseStudiesContainer class:list={["second-wrapper"]} /> -->
    <Skillsbox class:list={["second-wrapper"]} />
    <List class:list={["second-wrapper"]} />
    <BigCta class:list={["site-wrapper"]} />
  </main>

  <Footer />
</BaseLayout>
